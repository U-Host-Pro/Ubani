# Environment variables for local development and Cloudflare Pages

# For local development (client-side EmailJS)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# these are used by the Cloudflare Pages Function (`/functions/contact.ts`) and should be
# added to your Pages project via the dashboard or `wrangler.toml` secrets.
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_SERVICE_ID=your_service_id_here
EMAILJS_TEMPLATE_ID=your_template_id_here

# if you ever need front‑end environment variables, prefix with VITE_ (e.g. VITE_API_URL)